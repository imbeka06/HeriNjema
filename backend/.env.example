# ============================================================================
# HeriNjema Backend Configuration (.env.example)
# ============================================================================
# Copy this file to .env and fill in your actual values

# === SERVER & DATABASE ===
PORT=3000
NODE_ENV=development
SERVER_URL=http://localhost:3000

# PostgreSQL Database Connection
DB_USER=postgres
DB_HOST=localhost
DB_NAME=herijnjema_db
DB_PASSWORD=your_secure_password_here
DB_PORT=5432

# === JWT & SECURITY ===
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d

# === SAFARICOM M-PESA (Daraja API) ===
MPESA_CONSUMER_KEY=your_safaricom_consumer_key
MPESA_CONSUMER_SECRET=your_safaricom_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9ba9b9d4edbd000756386e8e12eb9f5f8e8c1b4e14e1af4ca9abedc82
MPESA_SANDBOX_URL=https://sandbox.safaricom.co.ke
MPESA_PRODUCTION_URL=https://api.safaricom.co.ke

# === AFRICA'S TALKING (USSD & SMS) ===
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_USERNAME=your_africas_talking_username
USSD_SHORTCODE=*384*123#

# === SHA/NHIF (Insurance Verification) ===
SHA_API_KEY=your_sha_api_key
SHA_API_URL=https://sha.healthapi.co.ke
NHIF_API_KEY=your_nhif_api_key
NHIF_API_URL=https://api.nhif.or.ke

# === WHATSAPP BUSINESS API (Twilio or Meta) ===
WHATSAPP_API_KEY=your_whatsapp_business_api_key
WHATSAPP_ACCOUNT_SID=your_twilio_account_sid
WHATSAPP_AUTH_TOKEN=your_twilio_auth_token
WHATSAPP_BUSINESS_PHONE=+254712345678

# === EMAIL (For verification & receipts) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_EMAIL=noreply@herinjema.co.ke

# === HL7 FHIR HOSPITAL EMR ===
EMR_PROVIDER=KenyaEMR
EMR_API_URL=http://hospital-emr-server:8080
EMR_API_KEY=your_emr_api_key
FHIR_SERVER_URL=http://fhir-server:8080/fhir

# === REDIS (Session Management) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# === BIOMETRIC SERVICE ===
BIOMETRIC_PROVIDER=auth0
BIOMETRIC_API_KEY=your_biometric_api_key

# === LOCATION SERVICE ===
MAPS_API_KEY=your_google_maps_api_key

# === LOGGING & MONITORING ===
LOG_LEVEL=info
SENTRY_DSN=your_sentry_dsn_for_error_tracking
